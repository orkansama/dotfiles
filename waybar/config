{
    "modules-left": [ "hyprland/workspaces" ],
    "modules-center": [ "clock" ],
    "modules-right": ["battery#BAT0", "battery#BAT1", "backlight", "memory", "network"],
    "hyprland/workspaces": {
		"format": "{name}: {icon}",
		"format-icons": {
			"1": "ΎΕι",
			"2": "ΌζΖ",
			"3": "ΎΒ╡",
			"4": "ΎΕκ",
			"5": "ΎΗ╝",
			"active": "ΎΗΤ",
			"default": "ΎΕΣ"
		},
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
        }
    },
    "memory": {
        "interval": 0,
        "format": "≤░Ξδ {}%",
        "max-length": 10
    },
    "backlight": {
        "format": "≤░Δη {}%",
    },
    "clock": {
        "tooltip-format": "{calendar}",
        "format-alt": "Ός░  {:%a, %d %b %Y}",
        "format": "ΎΡ║  {:%H:%M}"
    },
	"battery#BAT0": {
		"bat": "BAT0",
		"interval": 60,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"events": {
			"on-discharging-warning": "notify-send -u normal 'Low Battery'",
			"on-discharging-critical": "notify-send -u critical 'Very Low Battery'",
			"on-charging-100": "notify-send -u normal 'Battery Full!'"
		},
		"format": "{capacity}% {icon}",
		"format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
		"max-length": 25
	},
	"battery#BAT1": {
		"bat": "BAT1",
		"interval": 60,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"events": {
			"on-discharging-warning": "notify-send -u normal 'Low Battery'",
			"on-discharging-critical": "notify-send -u critical 'Very Low Battery'",
			"on-charging-100": "notify-send -u normal 'Battery Full!'"
		},
		"format": "{capacity}% {icon}",
		"format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
		"max-length": 25
	},
	"network": {
		"interval": 0,
		"format-wifi": "ΌυΒ {} ({signalStrength}%)",
		"format-ethernet": "{ifname} ΎΔΒ",
		"format-disconnected": "≤▒αΨ",
	}
}
