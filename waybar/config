{
    "modules-left": [ "hyprland/workspaces" ],
    "modules-center": [ "clock" ],
    "modules-right": ["group/scripts", "battery", "backlight", "memory", "network", "pulseaudio", "group/powersegment"],
    "hyprland/workspaces": {
		"format": "{name}: {icon}",
		"format-icons": {
			"1": "",
			"2": "",
			"3": "",
			"4": "",
			"5": "",
			"active": "",
			"default": ""
		},
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
        },
    },
    "memory": {
        "interval": 5,
        "format": "󰍛 {}%",
    },
	"network": {
		"interval": 5,
		"format-wifi": " {} ({signalStrength}%)",
		"format-ethernet": "{ifname}",
		"format-disconnected": "󱘖",
		"tooltip-format": "{ifname}",
	},
    "backlight": {
        "format": "󰃞 {}%",
		"tooltip-format": "󰃞  {}%",
		"on-click": "brightnessctl s 100%",
		"on-click-right": "brightnessctl s 50%",
		"on-click-middle": "brightnessctl s 0%"
    },
    "clock": {
		"timezone": "Europe/Berlin",
        "format-alt": "  {:%a, %d %b %Y}",
        "format": "  {:%H:%M}",
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"actions": {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
    },
	"battery": {
		"interval": 5,
		"format": "{capacity}% ",
	},
	"pulseaudio": {
		"format": "{volume}% ",
		"format-bluetooth": "{volume}% 󰂰",
		"format-muted": "󰝟",
		"scroll-step": 1,
		"on-click": "pavucontrol"
	},
	"custom/power": {
		"format": "󰐥",
		"on-click": "./scripts/shutdownScript.sh",
		"on-click-right": "./scripts/rebootScript.sh",
		"tooltip-format": "Left-Click: Shutdown, Right-Click: Reboot"
	},
	"custom/githubInbox": {
		"interval": 60,
		"format": " {percentage}",
		"return-type": "json",
		"exec": "./scripts/fetchGithubInbox.sh",
		"tooltip-format": "Unread Github notifications",
		"on-click": "xdg-open https://github.com/notifications",
	},
	"group/scripts": {
		"orientation": "horizontal",
		"modules": ["custom/githubInbox"]
	},

	"group/powersegment": {
		"orientation": "horizontal",
		"modules": ["custom/power"]
	},
}
