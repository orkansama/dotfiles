{
    "modules-left": [ "hyprland/workspaces" ],
    "modules-center": [ "clock" ],
    "modules-right": ["battery#BAT0", "battery#BAT1", "backlight", "memory", "network"],
    "hyprland/workspaces": {
		"format": "{name}: {icon}",
		"format-icons": {
			"1": "",
			"2": "",
			"3": "",
			"4": "",
			"5": "",
			"active": "",
			"default": ""
		},
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
        },
    },
    "memory": {
        "interval": 5,
        "format": "󰍛 {}%",
        "max-length": 10,
		"tooltip-format": "hello world"
    },
	"network": {
		"interval": 5,
		"format-wifi": " {} ({signalStrength}%)",
		"format-ethernet": "{ifname}",
		"format-disconnected": "󱘖",
		"tooltip-format": "Hello world"
	},
    "backlight": {
        "format": "󰃞 {}%",
		"tooltip-format": "Hello world"
    },
    "clock": {
		"timezone": "Europe/Berlin",
        "format-alt": "  {:%a, %d %b %Y}",
        "format": "  {:%H:%M}",
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"actions": {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
    },
	"battery#BAT0": {
		"bat": "BAT0",
		"interval": 60,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"events": {
			"on-discharging-warning": "notify-send -u normal 'Low Battery'",
			"on-discharging-critical": "notify-send -u critical 'Very Low Battery'",
			"on-charging-100": "notify-send -u normal 'Battery Full!'"
		},
		"format": "{capacity}% {icon}",
		"format-icons": ["", "", "", "", ""],
		"max-length": 25,
		"tooltip-format": "Hello world"
	},
	"battery#BAT1": {
		"bat": "BAT1",
		"interval": 60,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"events": {
			"on-discharging-warning": "notify-send -u normal 'Low Battery'",
			"on-discharging-critical": "notify-send -u critical 'Very Low Battery'",
			"on-charging-100": "notify-send -u normal 'Battery Full!'"
		},
		"format": "{capacity}% {icon}",
		"format-icons": ["", "", "", "", ""],
		"max-length": 25,
		"tooltip-format": "Hello world"
	},
}
