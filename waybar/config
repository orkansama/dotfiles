{
    "modules-left": [ "hyprland/workspaces" ],
    "modules-center": [ "clock" ],
    "modules-right": ["battery", "backlight", "memory", "network"],
    "hyprland/workspaces": {
		"format": "{name}: {icon}",
		"format-icons": {
			"1": "",
			"2": "",
			"3": "",
			"4": "",
			"5": "",
			"active": "",
			"default": ""
		},
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
        },
    },
    "memory": {
        "interval": 5,
        "format": "󰍛 {}%",
        "max-length": 10,
		"tooltip-format": "hello world"
    },
	"network": {
		"interval": 5,
		"format-wifi": " {} ({signalStrength}%)",
		"format-ethernet": "{ifname}",
		"format-disconnected": "󱘖",
		"tooltip-format": "Hello world"
	},
    "backlight": {
        "format": "󰃞 {}%",
		"tooltip-format": "󰃞  {}%",
		"on-click": "brightnessctl s 100%",
		"on-click-right": "brightnessctl s 50%",
		"on-click-middle": "brightnessctl s 0%"
		}
    },
    "clock": {
		"timezone": "Europe/Berlin",
        "format-alt": "  {:%a, %d %b %Y}",
        "format": "  {:%H:%M}",
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"actions": {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
    },
	"battery": {
		"interval": 5,
		"format": "{capacity}% ",
	},
}
